      <foregroundcolor></foregroundcolor>
      <headline>F</headline>
      <icon></icon>
      <kpiindex>6</kpiindex>
      <rangeindex>ALL</rangeindex>
      <threshold></threshold>
    </highlighting>
    <highlighting>
      <backgroundcolor>ffffff</backgroundcolor>
      <bold>F</bold>
      <condition>ALWAYS</condition>
      <foregroundcolor></foregroundcolor>
      <headline>T</headline>
      <icon></icon>
      <kpiindex>7</kpiindex>
      <rangeindex>1</rangeindex>
      <threshold></threshold>
    </highlighting>
  </highlightings>
</kpiscorecard>